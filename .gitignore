# =============================================================================
#  .gitignore — HKT IPSSI
#  Stack : Python (FastAPI + Django) • React (Node) • Docker • Airflow
# =============================================================================


# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
wheels/

# Environnements virtuels
venv/
.venv/
env/
.env/
ENV/


# ─── Variables d'environnement (NE JAMAIS commit) ────────────────────────────
.env
.env.*
!.env.example          # On garde le fichier d'exemple comme référence


# ─── Django ──────────────────────────────────────────────────────────────────
db.sqlite3
db.sqlite3-journal
django/staticfiles/
django/mediafiles/
django/media/
*.log


# ─── FastAPI ─────────────────────────────────────────────────────────────────
fastapi/__pycache__/
fastapi/*.pyc


# ─── Airflow ─────────────────────────────────────────────────────────────────
logs/
airflow.db
airflow.cfg
airflow_settings.yaml
standalone_admin_password.txt
unittests.cfg


# ─── React / Node ────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/build/
frontend/dist/
frontend/.pnp
frontend/.pnp.js
frontend/coverage/
frontend/.next/
frontend/out/
frontend/.cache/
frontend/package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*


# ─── Docker ──────────────────────────────────────────────────────────────────
# On garde les Dockerfile et docker-compose, mais pas les volumes locaux
docker-volumes/
postgres-data/
mongo-data/


# ─── IDEs & Éditeurs ─────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db


# ─── Tests & Coverage ────────────────────────────────────────────────────────
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.tox/
nosetests.xml
coverage.xml
*.cover


# ─── Fichiers sensibles / uploads locaux ─────────────────────────────────────
*.pem
*.key
*.cert
*.p12
uploads/
data/raw/
data/clean/
data/curated/